{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    },
    {
      "src": "ai-bd-tracker/package.json",
      "use": "@vercel/static-build",
      "config": { 
        "distDir": "dist",
        "buildCommand": "npm run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/admin",
      "destination": "api/index.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/ai-bd-tracker/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}
