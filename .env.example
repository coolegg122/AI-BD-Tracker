# Copy to .env (repo root) and/or backend/.env for local development.
# For Vercel: Settings → Environment Variables (Production + Preview).

# --- Required for auth (use a strong random value in production) ---
# Generate: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production

# --- Database ---
# Local SQLite (default when no Postgres URL is set)
DATABASE_URL=sqlite:///./sql_app.db

# Production: Supabase transaction pooler (Serverless / Vercel), port 6543
# POSTGRES_URL=postgresql://postgres.<project_ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Alternative name also supported:
# DATABASE_URL=<same as above>

# Optional: direct / session connection (migrations, long sessions)
# POSTGRES_URL_NON_POOLING=postgresql://postgres:YOUR_PASSWORD@db.<project_ref>.supabase.co:5432/postgres

# Optional: scripts/verify_conn_pooler.py tries each URL until one works
# POOLER_TEST_URLS=postgresql://...,postgresql://...

# --- AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- Email sync (if used) ---
# ZOHO_EMAIL=
# ZOHO_PASSWORD=

# Vercel sets VERCEL=1 automatically; do not set locally unless testing.
